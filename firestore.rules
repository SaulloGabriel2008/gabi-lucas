rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function adminPath(uid) {
      return /databases/$(database)/documents/admins/$(uid);
    }

    function isAdmin() {
      return isSignedIn()
        && exists(adminPath(request.auth.uid))
        && get(adminPath(request.auth.uid)).data.active == true;
    }

    function familyPath(familyId) {
      return /databases/$(database)/documents/families/$(familyId);
    }

    function familyIsActive(familyId) {
      return exists(familyPath(familyId))
        && get(familyPath(familyId)).data.isActive == true;
    }

    match /admins/{userId} {
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /siteSettings/{settingId} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }

    match /gifts/{giftId} {
      allow read: if isAdmin() || resource.data.isActive == true;
      allow create, update, delete: if isAdmin();
    }

    match /tables/{tableId} {
      allow read, write: if isAdmin();
    }

    match /inviteLinks/{slug} {
      allow get: if isAdmin() || resource.data.isActive == true;
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /families/{familyId} {
      allow get: if isAdmin() || resource.data.isActive == true;
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        resource.data.isActive == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'attendanceNote',
          'updatedAt'
        ])
      );

      match /guests/{guestId} {
        allow get, list: if isAdmin() || familyIsActive(familyId);
        allow create, delete: if isAdmin();
        allow update: if isAdmin() || (
          familyIsActive(familyId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'responseStatus',
            'updatedAt'
          ])
          && (
            request.resource.data.responseStatus == 'pending'
            || request.resource.data.responseStatus == 'confirmed'
            || request.resource.data.responseStatus == 'declined'
          )
        );
      }
    }
  }
}
