rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function adminPath(uid) {
      return /databases/$(database)/documents/admins/$(uid);
    }

    function normalizedEmail() {
      return request.auth.token.email.lower();
    }

    function adminEmailPath(email) {
      return /databases/$(database)/documents/adminEmails/$(email);
    }

    function adminDocIsActive(path) {
      return exists(path)
        && (
          get(path).data.active == true
          || get(path).data.active == 'true'
        );
    }

    function isAdmin() {
      return isSignedIn()
        && (
          adminDocIsActive(adminPath(request.auth.uid))
          || (
            request.auth.token.email is string
            && request.auth.token.email != ''
            && adminDocIsActive(adminEmailPath(normalizedEmail()))
          )
        );
    }

    function familyPath(familyId) {
      return /databases/$(database)/documents/families/$(familyId);
    }

    function invitePath(slug) {
      return /databases/$(database)/documents/inviteLinks/$(slug);
    }

    function inviteIsActiveForFamily(slug, familyId) {
      return slug is string
        && slug != ''
        && exists(invitePath(slug))
        && get(invitePath(slug)).data.isActive == true
        && get(invitePath(slug)).data.familyId == familyId;
    }

    function familyIsActive(familyId) {
      return exists(familyPath(familyId))
        && get(familyPath(familyId)).data.isActive == true;
    }

    function familyInviteIsActive(familyId) {
      return familyIsActive(familyId)
        && inviteIsActiveForFamily(get(familyPath(familyId)).data.slug, familyId);
    }

    match /admins/{userId} {
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /adminEmails/{emailId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /siteSettings/{settingId} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }

    match /gifts/{giftId} {
      allow read: if isAdmin() || resource.data.isActive == true;
      allow create, update, delete: if isAdmin();
    }

    match /tables/{tableId} {
      allow read, write: if isAdmin();
    }

    match /inviteLinks/{slug} {
      allow get: if isAdmin() || resource.data.isActive == true;
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /families/{familyId} {
      allow get: if isAdmin() || (
        resource.data.isActive == true
        && inviteIsActiveForFamily(resource.data.slug, familyId)
      );
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        familyInviteIsActive(familyId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'attendanceNote',
          'updatedAt'
        ])
      );

      match /guests/{guestId} {
        allow get, list: if isAdmin() || familyInviteIsActive(familyId);
        allow create, delete: if isAdmin();
        allow update: if isAdmin() || (
          familyInviteIsActive(familyId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'responseStatus',
            'updatedAt'
          ])
          && (
            request.resource.data.responseStatus == 'pending'
            || request.resource.data.responseStatus == 'confirmed'
            || request.resource.data.responseStatus == 'declined'
          )
        );
      }
    }
  }
}
