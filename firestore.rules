rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "admin@anaelucas.local";
    }

    function isActiveFamily(inviteId) {
      return get(/databases/$(database)/documents/guestFamilies/$(inviteId)).data.isActive == true;
    }

    match /siteSettings/{settingId} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }

    match /giftItems/{giftId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /tables/{tableId} {
      allow read, write: if isAdmin();
    }

    match /guestFamilies/{inviteId} {
      allow get: if isAdmin() || resource.data.isActive == true;
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        resource.data.isActive == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'attendanceNote',
          'updatedAt'
        ])
        && request.resource.data.slug == resource.data.slug
        && request.resource.data.familyName == resource.data.familyName
        && request.resource.data.displayName == resource.data.displayName
        && request.resource.data.customMessage == resource.data.customMessage
        && request.resource.data.isActive == resource.data.isActive
        && request.resource.data.createdAt == resource.data.createdAt
      );

      match /members/{memberId} {
        allow get, list: if isAdmin() || isActiveFamily(inviteId);
        allow create, delete: if isAdmin();
        allow update: if isAdmin() || (
          isActiveFamily(inviteId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'responseStatus',
            'updatedAt'
          ])
          && request.resource.data.name == resource.data.name
          && request.resource.data.tableId == resource.data.tableId
          && request.resource.data.createdAt == resource.data.createdAt
          && (
            request.resource.data.responseStatus == 'confirmed'
            || request.resource.data.responseStatus == 'declined'
          )
        );
      }
    }
  }
}
